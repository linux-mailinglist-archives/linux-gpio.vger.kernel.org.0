-static int clk_ddram_is_enabled(struct clk_hw *hw)
-{
-	struct lpc32xx_clk *clk = to_lpc32xx_clk(hw);
-	u32 val;
-
-	regmap_read(clk_regmap, clk->reg, &val);
-	val &= clk->enable_mask | clk->busy_mask;
-
-	return (val == (BIT(7) | BIT(0)) ||
-		val == (BIT(8) | BIT(1)));
-}
