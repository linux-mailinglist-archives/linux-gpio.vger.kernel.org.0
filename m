-static u8 clk_mux_get_parent(struct clk_hw *hw)
-{
-	struct lpc32xx_clk_mux *mux = to_lpc32xx_mux(hw);
-	u32 num_parents = clk_hw_get_num_parents(hw);
-	u32 val;
-
-	regmap_read(clk_regmap, mux->reg, &val);
-	val >>= mux->shift;
-	val &= mux->mask;
-
-	if (mux->table) {
-		u32 i;
-
-		for (i = 0; i < num_parents; i++)
-			if (mux->table[i] == val)
-				return i;
-		return -EINVAL;
-	}
-
-	if (val >= num_parents)
-		return -EINVAL;
-
-	return val;
-}
