-static void clk_creg_disable(struct clk_hw *hw)
-{
-	struct clk_creg_data *creg = to_clk_creg(hw);
-
-	regmap_update_bits(creg->reg, LPC18XX_CREG_CREG0,
-			   creg->en_mask, 0);
