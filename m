-static int clk_mux_set_parent(struct clk_hw *hw, u8 index)
-{
-	struct lpc32xx_clk_mux *mux = to_lpc32xx_mux(hw);
-
-	if (mux->table)
-		index = mux->table[index];
-
-	return regmap_update_bits(clk_regmap, mux->reg,
-			  mux->mask << mux->shift, index << mux->shift);
-}
