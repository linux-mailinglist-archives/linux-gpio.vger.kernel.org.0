-static void __init lpc32xx_clk_div_quirk(u32 reg, u32 div_mask, u32 gate)
-{
-	u32 val;
-
-	regmap_read(clk_regmap, reg, &val);
-
-	if (!(val & div_mask)) {
-		val &= ~gate;
-		val |= BIT(__ffs(div_mask));
-	}
-
-	regmap_update_bits(clk_regmap, reg, gate | div_mask, val);
-}
