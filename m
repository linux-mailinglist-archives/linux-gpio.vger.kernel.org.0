-	struct clk_creg_data *creg = to_clk_creg(hw);
-	u32 reg;
-
-	regmap_read(creg->reg, LPC18XX_CREG_CREG0, &reg);
-
-	return !(reg & LPC18XX_CREG_CREG0_PD32KHZ) &&
-	       !(reg & LPC18XX_CREG_CREG0_RESET32KHZ);
-}
