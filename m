-					   unsigned long parent_rate)
-{
-	struct lpc32xx_clk *clk = to_lpc32xx_clk(hw);
-	u32 val;
-
-	if (!clk_ddram_is_enabled(hw))
-		return 0;
-
-	regmap_read(clk_regmap, clk->reg, &val);
-	val &= clk->enable_mask;
-
-	return parent_rate / (val >> 7);
-}
